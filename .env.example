# Supabase — create a free project at https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Moyasar (Phase 2)
MOYASAR_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_MOYASAR_PUBLISHABLE_KEY=pk_test_xxx
MOYASAR_API_BASE_URL=https://api.moyasar.com/v1

# Email (report digests + first-login 2FA codes via Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM=Scop <reports@yourdomain.com>

# Cron — protect /api/cron/* routes
CRON_SECRET=generate-a-random-secret
